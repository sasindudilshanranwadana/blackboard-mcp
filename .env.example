# ─────────────────────────────────────────────
#  Blackboard MCP — CDU Learnline Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your details
# NEVER commit .env to git

# CDU Learnline base URL (do not add a trailing slash)
BB_BASE_URL=https://learnline.cdu.edu.au

# Your CDU student credentials
BB_USERNAME=your_student_number
BB_PASSWORD=your_password

# Where to cache your session cookies locally (keeps you logged in between restarts)
BB_SESSION_CACHE=~/.bb_mcp_session.json

# Set to "false" to watch the login browser window (useful for debugging)
BB_HEADLESS=true
